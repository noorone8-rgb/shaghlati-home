# انسخ هذا الملف إلى .env محلياً، وعلى Railway أضِف هذه المتغيرات في Variables
PORT=3000

# سر توقيع الجلسات (JWT) — استخدم قيمة عشوائية طويلة وسرية في الإنتاج
JWT_SECRET=change-this-to-a-long-random-secret

# رقم هاتف حساب المدير
ADMIN_PHONE=07893799524

# رقم واتساب الاستقبال
WHATSAPP=9647893799524

# رسوم التوصيل الافتراضية (دينار)
DELIVERY_FEE=5000

# ── خاص بالاستضافة مع قرص دائم (Railway Volume) ──
# اربط Volume على المسار /data ثم فعّل السطرين التاليين:
# DB_PATH=/data/shaghlati.db
# UPLOADS_DIR=/data/uploads
